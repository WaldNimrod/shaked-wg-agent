{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AOS Dashboard (L2)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "core.modules.management.api:app",
        "--host", "127.0.0.1",
        "--port", "8090",
        "--reload"
      ],
      "env": {
        "AOS_V3_DATABASE_URL": "postgresql://aos:aos_dev_local@127.0.0.1:5434/aos_v3"
      },
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
