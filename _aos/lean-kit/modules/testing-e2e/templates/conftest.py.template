import os
import pytest
from playwright.sync_api import Playwright

# ---------------------------------------------------------------------------
# AOS canonical environment variables — names are fixed across all spokes
# ---------------------------------------------------------------------------
_BASE_URL = os.environ["AOS_E2E_BASE_URL"]
_E2E_USER = os.environ["AOS_E2E_USER"]
_E2E_PASS = os.environ["AOS_E2E_PASS"]

# Storage state path: override via env or use the spoke-configured default
_STORAGE_STATE_PATH = os.environ.get(
    "AOS_E2E_STORAGE_STATE_PATH", "{{AOS_E2E_STORAGE_STATE_PATH}}"
)


# ---------------------------------------------------------------------------
# Session-scoped login fixture
# Runs ONCE per pytest session; saves browser storage state to disk.
# Subsequent tests load the saved state instead of re-authenticating.
# ---------------------------------------------------------------------------
@pytest.fixture(scope="session")
def login_and_save_storage(playwright: Playwright) -> None:
    """Perform login once for the session and persist storage state."""
    browser = playwright.chromium.launch()
    context = browser.new_context()
    page = context.new_page()

    page.goto(f"{_BASE_URL}/{{AOS_E2E_LOGIN_PATH}}")
    page.fill("{{AOS_E2E_USER_SELECTOR}}", _E2E_USER)
    page.fill("{{AOS_E2E_PASS_SELECTOR}}", _E2E_PASS)
    page.click("{{AOS_E2E_SUBMIT_SELECTOR}}")
    page.wait_for_url(f"{_BASE_URL}/{{AOS_E2E_POST_LOGIN_PATH}}")

    # Persist cookies + localStorage so other fixtures can reuse without login
    import pathlib
    pathlib.Path(_STORAGE_STATE_PATH).parent.mkdir(parents=True, exist_ok=True)
    context.storage_state(path=_STORAGE_STATE_PATH)

    browser.close()


# ---------------------------------------------------------------------------
# Session-scoped storage state fixture
# Depends on login_and_save_storage — guarantees state file exists.
# Usage in test: browser.new_context(storage_state=storage_state)
# ---------------------------------------------------------------------------
@pytest.fixture(scope="session")
def storage_state(login_and_save_storage) -> str:  # noqa: ARG001
    """Return the path to the persisted storage state file."""
    return _STORAGE_STATE_PATH


# ---------------------------------------------------------------------------
# Authenticated page fixture (function-scoped)
# Creates a fresh browser context pre-loaded with saved auth state.
# Each test gets its own page; auth is not re-performed.
# ---------------------------------------------------------------------------
@pytest.fixture()
def auth_page(playwright: Playwright, storage_state: str):
    """Yield an authenticated Playwright page; close after test."""
    browser = playwright.chromium.launch()
    context = browser.new_context(storage_state=storage_state)
    page = context.new_page()
    yield page
    context.close()
    browser.close()
