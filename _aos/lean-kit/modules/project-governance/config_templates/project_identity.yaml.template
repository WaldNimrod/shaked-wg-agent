# _aos/project_identity.yaml — Cross-Project Boundary Declaration
# ================================================================
# SSoT for project identity and boundary enforcement.
# Read by: validate_aos.sh (Check 12), .cursorrules, CLAUDE.md, activation prompts, prompt builder.
# Managed by: Team 00 + Team 100.
# Deployed to: _aos/project_identity.yaml in every AOS-managed project.
#
# TEMPLATE — replace {{placeholders}} with project-specific values.

project_id: "{{project_id}}"
display_name: "{{display_name}}"
domain: "{{domain}}"
profile: "{{profile}}"                    # L0 | L2 | L2.5 | L3

# Hub-spoke topology
is_hub: {{is_hub}}                        # true only for agents-os
managed_projects: {{managed_projects}}    # list of project_ids this hub manages (empty for spokes)

# Boundary enforcement
boundaries:
  # Directories this project's agents may write to (relative to repo root)
  allowed_write_roots:
    {{allowed_write_roots}}

  # Patterns that must NEVER appear in tracked files (other project names, domains, imports)
  forbidden_patterns:
    {{forbidden_patterns}}

  # Instruction for agents encountering cross-project work
  cross_project_routing: "{{cross_project_routing}}"

  # Push scope: "push everything" always means this repo only — never cross-repo
  # Allowed values: repo_only (all profiles, hub and spoke)
  push_scope: repo_only         # push commands always target this repo only, regardless of topology

  # for_hub routing: how AOS-level artifacts discovered here reach the hub
  # Allowed values: via_team_00 (spokes, is_hub:false) | self (hub, is_hub:true)
  # When is_hub:false — flag artifact with for_hub:true; Team 00 routes to hub in a separate AOS session
  # When is_hub:true  — hub writes directly to its own _COMMUNICATION/team_100/
  hub_routing: "{{hub_routing}}"   # via_team_00 for spokes | self for hub
