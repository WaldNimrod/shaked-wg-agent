# _aos/definition.yaml — Project Team Definition Snapshot
#
# SNAPSHOT of active teams from the hub's core/definition.yaml.
# Enables this project to function independently (Iron Rule #8).
#
# Source: agents-os/core/definition.yaml (hub SSoT)
# Snapshot date: {{DATE}}
# Snapshot by: {{AUTHOR}}
#
# IRON RULE: Physical copy only — never symlink. Updates via explicit refresh.
# Contains: active project teams only (team_00, team_100, team_110, team_190 + any project-specific teams).
#
# RULE: every team_XX key here must have a corresponding _aos/governance/team_XX.md
# Ghost teams (defined here but not governed) will fail validate_aos.sh Check 13.
# Remove any team block below that is NOT in your team_assignments.yaml.

version: "1.0.0"
source_ref: "core/definition.yaml"
snapshot_date: "{{DATE}}"
profile: {{PROFILE}}

# ============================================================
# MULTI-DOMAIN TEAMS — always required in every project
# ============================================================

team_00:
  id: team_00
  label: Team 00
  name: System Designer (Principal)
  engine: human
  group: leadership
  profession: principal
  role_description: "Human owner. Sets all Iron Rules, holds final approval, defines product vision and constraints."

team_100:
  id: team_100
  label: Team 100
  name: Chief System Architect
  engine: claude-code
  group: architecture
  profession: chief_architect
  role_description: "Program-level architecture and synthesis. GATE_2 owner. Coordinates domain architects and execution teams."

team_190:
  id: team_190
  label: Team 190
  name: Constitutional Validator
  engine: openai
  group: governance
  profession: constitutional_validator
  role_description: "Cross-engine validation authority. L-GATE_VALIDATE constitutional review. Must differ from builder engine (Iron Rule #1)."

# ============================================================
# UNIVERSAL PROJECT TEAMS — include only what is in team_assignments.yaml
# ============================================================

# Required for all projects with a domain builder:
team_110:
  id: team_110
  label: Team 110
  name: Domain Builder Agent
  engine: cursor-composer
  group: implementation
  profession: domain_builder
  role_description: "Implements against LOD400 specs. Owns L-GATE_BUILD exit. Must differ from validator engine."

