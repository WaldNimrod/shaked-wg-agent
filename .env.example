# Copy to .env (gitignored). uPress is the same host as SmallFarmsAgents (SFA); paths differ by WordPress folder.
#
# Quick merge from SFA (optional):
#   bash scripts/env_from_sfa.sh
# Server-side equivalent: deploy/setup_server.sh
#
# Required for FTPS publish:
UPRESS_SFTP_HOST=ftp.s887.upress.link
UPRESS_SFTP_PORT=21
UPRESS_SFTP_USER=mezoohost@nimrod.bio
UPRESS_SFTP_PASS=
# If the password contains $ or spaces, quote it: UPRESS_SFTP_PASS='...'
UPRESS_PUBLIC_BASE=https://www.nimrod.bio
#
# Optional global override (same path for every profile). Usually LEAVE UNSET so the app can use:
#   default → wp-content/uploads/shaked-wg
#   dror    → wp-content/uploads/shaked-wg/dror
# UPRESS_UPLOAD_PATH=agents/shaked-wg
#
# WordPress REST (optional; not required for HTML upload):
UPRESS_WP_REST_BASE=https://www.nimrod.bio/wp-json
UPRESS_WP_APP_USER=agent
UPRESS_WP_APP_PASS=

# --- S003-P001-WP001 — PostgreSQL persistence (optional; default remains JSON files) ---
# PERSISTENCE_BACKEND=json
# SHAKED_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/shaked_wg
# SHAKED_LEGACY_TENANT_SLUG=legacy
# SHAKED_BOOTSTRAP_USER_EMAIL=bootstrap@local.invalid
